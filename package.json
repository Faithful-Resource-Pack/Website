{
	"name": "faithful-website",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "nuxt build",
		"dev": "nuxt dev",
		"generate": "nuxt generate",
		"preview": "nuxt preview",
		"start": "node .output/server/index.mjs",
		"postinstall": "nuxt prepare",
		"lint": "eslint .",
		"prettier": "prettier \"{,!(node_modules)/**/}*.{js,vue,html,ts}\" --write",
		"docker:build": "docker build --tag faithful-website .",
		"docker:start": "docker run -d -p 3000:3000 faithful-website",
		"docker:alive": "curl -s -o /dev/null -w \"%{http_code} %{content_type}\" http://localhost:3000 | grep -q \"^200 text/html\""
	},
	"dependencies": {
		"isomorphic-dompurify": "^3.17.0",
		"luxon": "^3.7.2",
		"marked": "^18.0.5",
		"nuxt": "^4.4.8",
		"remove-markdown": "^0.6.4",
		"sass": "^1.101.0",
		"vue": "^3.5.38",
		"vuetify-nuxt-module": "^0.19.5",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@nuxt/eslint": "1.16.0",
		"@types/luxon": "^3.7.1",
		"eslint": "^10.5.0",
		"prettier": "^3.8.4"
	},
	"peerDependencies": {
		"vuetify": "3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"esbuild",
			"unrs-resolver"
		]
	}
}
